---
import type { CollectionEntry } from "astro:content";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", data } = Astro.props;
const { title, description, koreanSummary, ...props } = data;

// Extract arXiv URL from description: "[arXiv](https://arxiv.org/abs/...) — ..."
const arXivMatch = description?.match(/\[arXiv\]\((https?:\/\/[^)]+)\)/);
const arXivUrl   = arXivMatch?.[1] ?? "#";
---

<li class="my-6 border-b border-border pb-6 last:border-0">
  <a
    href={arXivUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="inline-block font-medium text-accent decoration-dashed underline-offset-4 hover:underline focus-visible:no-underline"
  >
    <Heading class="text-base sm:text-lg leading-snug">{title}</Heading>
  </a>

  <Datetime {...props} class="mt-1" />

  {koreanSummary && (
    <p class="mt-2 text-sm leading-relaxed opacity-75">{koreanSummary}</p>
  )}
</li>
