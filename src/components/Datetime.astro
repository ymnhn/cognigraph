---
import dayjs from "dayjs";
import utc from "dayjs/plugin/utc";
import timezone from "dayjs/plugin/timezone";
import IconCalendar from "@/assets/icons/IconCalendar.svg";
import { SITE } from "@/config";

dayjs.extend(utc);
dayjs.extend(timezone);

type Props = { pubDatetime: string | Date; class?: string };
const { pubDatetime, class: cls = "" } = Astro.props;
const dt = dayjs(pubDatetime).tz(SITE.timezone);
---

<div class:list={["flex items-center gap-1.5 text-sm opacity-55", cls]}>
  <IconCalendar class="size-3.5 shrink-0" />
  <time datetime={dt.toISOString()}>{dt.format("D MMM YYYY")}</time>
</div>
