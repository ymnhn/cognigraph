---
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Layout from "./Layout.astro";
import { SITE } from "@/config";

// 1. Astro.props를 any로 받아 엔진의 자동 검증 로직을 우회합니다.
const props = Astro.props as any;
const { frontmatter } = props;

// 2. 제목 설정 (Markdown에 title이 없을 경우를 대비한 2중 방어)
const pageTitle = frontmatter?.title || "About";
const fullTitle = `${pageTitle} | ${SITE.title}`;
---

<!-- 3. 부모 레이아웃인 Layout.astro에 전달하는 값이 확실한지 확인 -->
<Layout title={fullTitle}>
  <!-- 4. 컴포넌트가 존재하지 않을 경우(undefined) 렌더링을 시도하지 않도록 방어 -->
  {Header && <Header />}
  {Breadcrumb && <Breadcrumb />}
  
  <main id="main-content" class="app-layout">
    <section id="about" class="app-prose mb-28 max-w-app prose-img:border-0">
      <h1 class="text-2xl tracking-wider sm:text-3xl">{pageTitle}</h1>
      <slot />
    </section>
  </main>

  {Footer && <Footer />}
</Layout>