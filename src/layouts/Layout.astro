---
// src/layouts/Layout.astro 수정
import { ViewTransitions } from "astro:transitions";
import { SITE } from "@/config";
import "@/styles/global.css";

// 모든 Props를 any로 받아 내부에서 안전하게 매핑
const props = Astro.props as any;

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = SITE.desc,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  scrollSmooth = false,
  // Markdown에서 넘어올 수 있는 여러 이름들을 수용
  pubDatetime,
  pubDate,
  pubDateContent,
  modDatetime,
  modDate,
  modDateContent,
} = props;

// 실제 사용할 날짜 데이터 결정 (우선순위 부여)
const rawPubDate = pubDateContent || pubDatetime || pubDate;
const rawModDate = modDateContent || modDatetime || modDate;

const PUBLIC_GOOGLE_SITE_VERIFICATION = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const socialImageURL = new URL(ogImage, Astro.url);

// 날짜 변환 함수 (undefined/null에 매우 방어적)
const formatISO = (date: any) => {
  if (!date) return null;
  const d = new Date(date);
  return isNaN(d.getTime()) ? null : d.toISOString();
};

const datePublishedStr = formatISO(rawPubDate);
const dateModifiedStr = formatISO(rawModDate);

const structuredData: any = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  image: socialImageURL.href,
  author: [{ "@type": "Person", name: author, ...(profile && { url: profile }) }],
};

if (datePublishedStr) structuredData.datePublished = datePublishedStr;
if (dateModifiedStr) structuredData.dateModified = dateModifiedStr;
---

<!doctype html>
<html dir={SITE.dir} lang={SITE.lang ?? "en"} class={`${scrollSmooth && "scroll-smooth"}`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>

    {datePublishedStr && <meta property="article:published_time" content={datePublishedStr} />}
    {dateModifiedStr && <meta property="article:modified_time" content={dateModifiedStr} />}
    
    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
    <ViewTransitions />
  </head>
  <body>
    <slot />
  </body>
</html>