---
import { ViewTransitions } from "astro:transitions";
import { SITE } from "@/config";
import "@/styles/global.css";

// 1. Astro 엔진이 Props를 검사하지 못하도록 any로 전개하여 복사합니다.
const props = { ...Astro.props } as any;

// 2. Markdown frontmatter와 루트 props를 합쳐서 변수를 할당합니다.
// null 병합 연산자를 사용하여 undefined일 경우의 접근을 사전에 차단합니다.
const title = props.title || props.frontmatter?.title || SITE.title;
const description = props.description || props.frontmatter?.description || SITE.desc;
const author = props.author || props.frontmatter?.author || SITE.author;
const profile = props.profile || props.frontmatter?.profile || SITE.profile;
const ogImage = props.ogImage || props.frontmatter?.ogImage || (SITE.ogImage ? `/${SITE.ogImage}` : "/og.png");
const canonicalURL = new URL(Astro.url.pathname, Astro.url);

// 3. 문제의 원인인 날짜 처리: 절대 toString()이 자동 호출되지 않도록 방어합니다.
const getSafeDate = (val: any) => {
  if (!val) return null;
  const d = new Date(val);
  return isNaN(d.getTime()) ? null : d.toISOString();
};

const datePublishedStr = getSafeDate(props.pubDatetime || props.frontmatter?.pubDatetime);
const dateModifiedStr = getSafeDate(props.modDatetime || props.frontmatter?.modDatetime);

const socialImageURL = new URL(ogImage, Astro.url);

const structuredData = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  image: socialImageURL.href,
  author: [{ "@type": "Person", name: author, ...(profile && { url: profile }) }],
  ...(datePublishedStr && { datePublished: datePublishedStr }),
  ...(dateModifiedStr && { dateModified: dateModifiedStr }),
};
---

<!doctype html>
<html lang={SITE.lang ?? "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:title" content={title} />
    <meta property="og:image" content={socialImageURL} />

    {datePublishedStr && <meta property="article:published_time" content={datePublishedStr} />}
    {dateModifiedStr && <meta property="article:modified_time" content={dateModifiedStr} />}

    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

    <ViewTransitions />
  </head>
  <body>
    <slot />
  </body>
</html>