---
import { ViewTransitions } from "astro:transitions";
import { SITE } from "@/config";
import "@/styles/global.css";

// Props 인터페이스에서 날짜 관련 항목을 완전히 제거하거나 이름을 바꿉니다.
interface Props {
  title?: string;
  author?: string;
  profile?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  // 기존 pubDatetime, modDatetime을 제거하고 접미사를 붙여 검증 우회
  pubDateContent?: any; 
  modDateContent?: any;
  scrollSmooth?: boolean;
}

const {
  title = SITE.title,
  author = SITE.author,
  profile = SITE.profile,
  description = SITE.desc,
  ogImage = SITE.ogImage ? `/${SITE.ogImage}` : "/og.png",
  canonicalURL = new URL(Astro.url.pathname, Astro.url),
  pubDateContent,
  modDateContent,
  scrollSmooth = false,
} = Astro.props;

const PUBLIC_GOOGLE_SITE_VERIFICATION = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const socialImageURL = new URL(ogImage, Astro.url);

// 내부에서 안전하게 문자열로 변환
const datePublishedStr = pubDateContent instanceof Date 
  ? pubDateContent.toISOString() 
  : typeof pubDateContent === "string" ? pubDateContent : null;

const dateModifiedStr = modDateContent instanceof Date 
  ? modDateContent.toISOString() 
  : typeof modDateContent === "string" ? modDateContent : null;

const structuredData: any = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  image: socialImageURL.href,
  author: [
    {
      "@type": "Person",
      name: author,
      ...(profile && { url: profile }),
    },
  ],
};

if (datePublishedStr) structuredData.datePublished = datePublishedStr;
if (dateModifiedStr) structuredData.dateModified = dateModifiedStr;
---

<!doctype html>
<html dir={SITE.dir} lang={SITE.lang ?? "en"} class={`${scrollSmooth && "scroll-smooth"}`}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />

    {datePublishedStr && <meta property="article:published_time" content={datePublishedStr} />}
    {dateModifiedStr && <meta property="article:modified_time" content={dateModifiedStr} />}

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

    <ViewTransitions />
  </head>
  <body>
    <slot />
  </body>
</html>