---
import { ViewTransitions } from "astro:transitions";
import { SITE } from "@/config";
import "@/styles/global.css";

// 1. Props 인터페이스 정의를 아예 삭제합니다. (엔진의 타입 검사 우회)
// 2. Astro.props를 전개 연산자로 복사하여 안전한 로컬 변수로 만듭니다.
const props = { ...Astro.props } as any;

// 3. Markdown frontmatter와 루트 props 중 어디서든 데이터를 가져오도록 매핑
const title = props.title || props.frontmatter?.title || SITE.title;
const author = props.author || props.frontmatter?.author || SITE.author;
const description = props.description || props.frontmatter?.description || SITE.desc;
const profile = props.profile || props.frontmatter?.profile || SITE.profile;
const ogImage = props.ogImage || props.frontmatter?.ogImage || (SITE.ogImage ? `/${SITE.ogImage}` : "/og.png");
const canonicalURL = new URL(Astro.url.pathname, Astro.url);

// 4. 날짜 처리: 가장 문제가 되는 부분입니다. 
// 값이 존재하는지 '속성' 수준에서 먼저 확인하고 Date 객체를 생성합니다.
const rawPub = props.pubDatetime || props.frontmatter?.pubDatetime;
const rawMod = props.modDatetime || props.frontmatter?.modDatetime;

const getSafeISO = (val: any) => {
  if (!val) return null;
  const d = new Date(val);
  return isNaN(d.getTime()) ? null : d.toISOString();
};

const datePublishedStr = getSafeISO(rawPub);
const dateModifiedStr = getSafeISO(rawMod);

const socialImageURL = new URL(ogImage, Astro.url);

// 5. 구조화 데이터 생성
const structuredData: any = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  image: socialImageURL.href,
  author: [
    {
      "@type": "Person",
      name: author,
      ...(profile && { url: profile }),
    },
  ],
};

if (datePublishedStr) structuredData.datePublished = datePublishedStr;
if (dateModifiedStr) structuredData.dateModified = dateModifiedStr;
---

<!doctype html>
<html lang={SITE.lang ?? "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={author} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />

    {datePublishedStr && <meta property="article:published_time" content={datePublishedStr} />}
    {dateModifiedStr && <meta property="article:modified_time" content={dateModifiedStr} />}

    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />

    <ViewTransitions />

    <script is:inline>
      (function () {
        const theme = localStorage.getItem("theme") || (window.matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light");
        document.firstElementChild?.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>