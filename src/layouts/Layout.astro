---
import { ViewTransitions } from "astro:transitions";
import { SITE } from "@/config";
import "@/styles/global.css";

// [핵심] Astro.props를 직접 구조 분해하지 않고 'any' 타입으로 캐스팅하여 
// 엔진이 toString()을 호출할 타겟(Property)을 찾지 못하게 합니다.
const props = Astro.props as any;

// 모든 데이터 추출을 'Optional Chaining'으로 처리하여 undefined 접근을 원천 차단
const title = props?.title || props?.frontmatter?.title || SITE.title;
const author = props?.author || props?.frontmatter?.author || SITE.author;
const description = props?.description || props?.frontmatter?.description || SITE.desc;
const ogImage = props?.ogImage || props?.frontmatter?.ogImage || (SITE.ogImage ? `/${SITE.ogImage}` : "/og.png");
const canonicalURL = new URL(Astro.url.pathname, Astro.url);

// 날짜 처리: null을 반환하여 메타 태그가 렌더링되지 않도록 유도
const safeISO = (d: any) => {
  if (!d) return null;
  try {
    const date = new Date(d);
    return isNaN(date.getTime()) ? null : date.toISOString();
  } catch {
    return null;
  }
};

const pubDate = safeISO(props?.pubDatetime || props?.frontmatter?.pubDatetime);
const modDate = safeISO(props?.modDatetime || props?.frontmatter?.modDatetime);
---

<!doctype html>
<html lang={SITE.lang ?? "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="" />
    <title>{title}</title>
    <meta name="description" content={description} />

    {pubDate && <meta property="article:published_time" content={pubDate} />}
    {modDate && <meta property="article:modified_time" content={modDate} />}

    <slot name="head" />

    <ViewTransitions />
  </head>
  <body>
    <slot />
  </body>
</html>