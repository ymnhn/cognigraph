---
// 1. Props 인터페이스를 완전히 제거하여 Astro 엔진의 사전 검증을 차단합니다.
import { ViewTransitions } from "astro:transitions";
import { SITE } from "@/config";
import "@/styles/global.css";

// 2. Astro.props를 직접 분해하지 말고, 로컬 변수에 안전하게 복사합니다.
const rawProps = Astro.props as any;

// 3. Optional Chaining(?.)을 극한으로 활용하여 undefined 접근을 원천 차단합니다.
// 'toString' 에러는 보통 여기서 자동 호출되려다 터집니다.
const title = rawProps?.title || rawProps?.frontmatter?.title || SITE.title;
const author = rawProps?.author || rawProps?.frontmatter?.author || SITE.author;
const description = rawProps?.description || rawProps?.frontmatter?.description || SITE.desc;
const profile = rawProps?.profile || rawProps?.frontmatter?.profile || SITE.profile;
const ogImage = rawProps?.ogImage || rawProps?.frontmatter?.ogImage || (SITE.ogImage ? `/${SITE.ogImage}` : "/og.png");
const canonicalURL = new URL(Astro.url.pathname, Astro.url);

// 4. 날짜 변환 함수를 별도로 선언하여 방어적으로 처리합니다.
const safeDate = (date: any) => {
  if (!date) return null;
  try {
    const d = new Date(date);
    return isNaN(d.getTime()) ? null : d.toISOString();
  } catch {
    return null;
  }
};

const datePublishedStr = safeDate(rawProps?.pubDatetime || rawProps?.frontmatter?.pubDatetime);
const dateModifiedStr = safeDate(rawProps?.modDatetime || rawProps?.frontmatter?.modDatetime);

const socialImageURL = new URL(ogImage, Astro.url);
---

<!doctype html>
<html lang={SITE.lang ?? "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={socialImageURL} />

    {datePublishedStr && <meta property="article:published_time" content={datePublishedStr} />}
    {dateModifiedStr && <meta property="article:modified_time" content={dateModifiedStr} />}

    <ViewTransitions />
  </head>
  <body>
    <slot />
  </body>
</html>