---
import { ViewTransitions } from "astro:transitions";
import { SITE } from "@/config";
import "@/styles/global.css";

// 1. 타입을 명시하지 않고 모든 데이터를 수용 (Astro 렌더러의 자동 검증 우회)
const { ...allProps } = Astro.props as any;

// 2. Markdown(frontmatter)에서 들어오든 직접 입력으로 들어오든 
// 속성 이름에 관계없이 데이터를 안전하게 추출
const title = allProps.title || allProps.frontmatter?.title || SITE.title;
const author = allProps.author || allProps.frontmatter?.author || SITE.author;
const description = allProps.description || allProps.frontmatter?.description || SITE.desc;
const ogImage = allProps.ogImage || allProps.frontmatter?.ogImage || (SITE.ogImage ? `/${SITE.ogImage}` : "/og.png");
const canonicalURL = new URL(Astro.url.pathname, Astro.url);

// 3. 날짜 처리: 'undefined'의 toString() 호출을 막기 위해 
// 속성 존재 여부를 먼저 확인하고 새 Date 객체 생성
const getIsoDate = (val: any) => {
  if (!val) return null;
  try {
    const d = new Date(val);
    return isNaN(d.getTime()) ? null : d.toISOString();
  } catch {
    return null;
  }
};

// frontmatter 내부와 루트 props 모두 확인
const datePublishedStr = getIsoDate(allProps.pubDatetime || allProps.frontmatter?.pubDatetime);
const dateModifiedStr = getIsoDate(allProps.modDatetime || allProps.frontmatter?.modDatetime);

const structuredData: any = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  image: new URL(ogImage, Astro.url).href,
  author: [{ "@type": "Person", name: author }],
};

if (datePublishedStr) structuredData.datePublished = datePublishedStr;
if (dateModifiedStr) structuredData.dateModified = dateModifiedStr;
---

<!doctype html>
<html lang={SITE.lang ?? "en"}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title}</title>
    <meta name="description" content={description} />

    {datePublishedStr && <meta property="article:published_time" content={datePublishedStr} />}
    {dateModifiedStr && <meta property="article:modified_time" content={dateModifiedStr} />}

    <script type="application/ld+json" is:inline set:html={JSON.stringify(structuredData)} />
    <ViewTransitions />
  </head>
  <body>
    <slot />
  </body>
</html>