---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { SITE } from "@/config";
---

<Layout title={`404 | ${SITE.title}`}>
  <Header />
  <main class="app-layout flex flex-1 items-center justify-center py-24">
    <div class="text-center">
      <p class="text-5xl font-semibold text-accent">404</p>
      <p class="mt-4 opacity-60">Page not found</p>
      <a href="/" class="mt-6 inline-block text-sm text-accent hover:underline">← Back home</a>
    </div>
  </main>
  <Footer />
</Layout>
