---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";

const posts = getSortedPosts(await getCollection("blog"));
const recent = posts.slice(0, SITE.postPerIndex);
const hasMore = posts.length > SITE.postPerIndex;
const allUrl = import.meta.env.BASE_URL.replace(/\/?$/, "/") + "posts/";
---

<Layout>
  <Header />
  <main id="main-content" class="app-layout pt-6 pb-4">
    <h1 class="mt-6 mb-0 text-2xl font-semibold">Today</h1>
    <ul>
      {recent.map(post => <Card {...post} />)}
    </ul>
    {hasMore && (
      <p class="mt-4 text-sm">
        <a href={allUrl} class="text-accent hover:underline decoration-dashed underline-offset-4">
          All papers →
        </a>
      </p>
    )}
  </main>
  <Footer />
</Layout>
